# ── Backend Configuration Template ───────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# NEVER COMMIT .env.local TO VERSION CONTROL.

# Application Settings
APP_ENV=development
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8082
BILL_SERVICE_URL=http://localhost:8081
LOG_LEVEL=info
LOG_FORMAT=text
GRACEFUL_SHUTDOWN_TIMEOUT=10

# Database & Infrastructure
DATABASE_URL=postgres://ss:ss@localhost:5433/pebble?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://ss:ss@localhost:5672/

# Security & Authentication (JWT)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# External Cloud Services (AWS)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=pebble-bills-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@pebble.in

# APIs & Integrations
GOOGLE_VISION_CREDENTIALS_PATH=./keys/google-vision.json
GEMINI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
FIREBASE_CREDENTIALS_PATH=./keys/firebase-adminsdk.json
SMALLCASE_API_KEY=
SMALLCASE_API_SECRET=
SMALLCASE_ENV=sandbox
ALPHA_VANTAGE_API_KEY=
OTP_PROVIDER=sns
MSG91_AUTH_KEY=

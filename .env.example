# ── Backend env vars (Jaipreeth) ─────────────────────────────────────────────
# Copy to .env.local and fill real values. Never commit real secrets.

# Server
APP_ENV=development
PORT=8080

# PostgreSQL (RDS in prod, local docker in dev)
DATABASE_URL=postgres://ss:ss@localhost:5432/pebble?sslmode=disable

# Redis (ElastiCache in prod)
REDIS_URL=redis://localhost:6379

# RabbitMQ (Amazon MQ in prod)
RABBITMQ_URL=amqp://ss:ss@localhost:5672/

# JWT (RS256 — generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# AWS (use IAM roles in ECS — these only needed for local dev)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=pebble-bills-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Vision API (OCR)
GOOGLE_VISION_CREDENTIALS_PATH=./keys/google-vision.json

# Google Gemini API (LLM scoring)
GEMINI_API_KEY=

# Razorpay (wallet topup)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Firebase Admin SDK (FCM push notifications)
FIREBASE_CREDENTIALS_PATH=./keys/firebase-adminsdk.json

# AWS SES (email)
SES_FROM_EMAIL=noreply@pebble.in

# Smallcase Partner API (broker)
SMALLCASE_API_KEY=
SMALLCASE_API_SECRET=
SMALLCASE_ENV=sandbox   # sandbox | production

# NSE / market data
ALPHA_VANTAGE_API_KEY=

# Phone OTP (AWS SNS or Msg91)
OTP_PROVIDER=sns         # sns | msg91
MSG91_AUTH_KEY=
